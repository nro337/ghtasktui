{
  "name": "ghtasktui",
  "version": "0.1.1",
  "description": "A Linear-inspired TUI for GitHub Projects, powered by the gh CLI",
  "author": "Nick Alico <nickalico.me>",
  "type": "module",
  "bin": {
    "ghtasktui": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pkg:linux": "pkg dist/cli.js --target node20-linux-x64 --output bin/ghtasktui-linux",
    "pkg:macos-x64": "pkg dist/cli.js --target node20-macos-x64 --output bin/ghtasktui-macos-x64",
    "pkg:macos-arm64": "pkg dist/cli.js --target node20-macos-arm64 --output bin/ghtasktui-macos-arm64",
    "pkg:win": "pkg dist/cli.js --target node20-win-x64 --output bin/ghtasktui-win.exe",
    "pkg:all": "npm run pkg:linux && npm run pkg:macos-x64 && npm run pkg:macos-arm64 && npm run pkg:win",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "github",
    "projects",
    "tui",
    "cli",
    "terminal",
    "linear"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "execa": "^9.4.0",
    "fuse.js": "^7.0.0",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@yao-pkg/pkg": "^5.13.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  },
  "pkg": {
    "assets": [],
    "targets": [
      "node20-linux-x64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-win-x64"
    ],
    "outputPath": "bin"
  }
}
